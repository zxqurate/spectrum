# Monitor layout — copy to monitors.conf and edit for your hardware.
#
# Quick setup with nwg-displays (recommended):
#   nwg-displays
#   (arrange monitors, then export/save to this file)
#
# Manual format:
#   monitor=NAME,RESOLUTION@REFRESH,POSITION,SCALE
#
# Examples:
# monitor=,preferred,auto,1
# monitor=HDMI-A-1,1920x1080@60,0x0,1
# monitor=eDP-1,2560x1600@165,1920x0,1.25

monitor=DP-1,1920x1080@180.0,0x0,1.0
monitor=DP-3,1920x1080@144.0,1920x0,1.0
