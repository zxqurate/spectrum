# Auto-managed by Quickshell Settings Panel — do not edit by hand

general {
    border_size = 0
}

decoration {
    rounding = 10

    blur {
        enabled           = true
        size              = 6
        passes            = 1
        xray              = false
        new_optimizations = true
        ignore_opacity    = true
        brightness        = 1.00
        contrast          = 1.00
        vibrancy          = 0.00
        vibrancy_darkness = 0.00
    }

    shadow {
        enabled      = false
        range        = 12
        render_power = 2
        color        = rgba(00000066)
    }

    active_opacity   = 0.92
    inactive_opacity = 0.88
}

animations {
    enabled = true

    animation = windows,    1, 6, easeOut,   slide
    animation = windowsOut, 1, 5, easeInOut, slide
    animation = border,     1, 8, easeOut
    animation = fade,       1, 7, easeOut
    animation = workspaces, 1, 6, easeOut,   slide
}

input {
    kb_layout   = us,ru
    sensitivity = 0.00

    touchpad {
        natural_scroll = true
    }
}

# quickshell-system-blur=true
# quickshell-border-size=2
# quickshell-panel-opacity=0.72
# quickshell-panel-card-opacity=0.78
